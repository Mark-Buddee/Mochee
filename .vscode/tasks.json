{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "cppbuild",
			"command": "gcc",
			"args": [
				// --- 1. FREQUENT TOGGLES (The "Switches") ---
				// "-DNDEBUG",              // Release mode (no asserts)
				// "-fprofile-generate",       // Enable profiling
				// "-fprofile-use",         // Use profiling data
				// "-fsanitize=address",    // Memory safety
				// "-fsanitize=undefined",  // Undefined behavior checks
				// "-ffast-math",           // Extreme math optimization

				// --- 2. CORE COMPILER SETTINGS ---
				"-g",                       // Debug symbols
				"-O3",                      // High optimization
				"-march=native",            // CPU specific tuning
				"-flto",                    // Link time optimization
				"-fdiagnostics-color=always",

				// --- 3. PROFILING CONFIGURATION ---
				"-fprofile-dir=build/profile_data",
				"-fprofile-prefix-path=${workspaceFolder}",

				// --- 4. WARNINGS & STANDARDS ---
				"-Wall",
				"-Wextra",
				"-Wunused",

				// --- 5. INCLUDES & SEARCH PATHS ---
				"-Iinc",
				"-Ideps/tinycthread",

				// --- 6. SOURCE FILES ---
				"src/*.c",
				"deps/tinycthread/*.c",

				// --- 7. OUTPUT & LINKING ---
				"-o", "mochee.exe",
				"-lm"
			],
		   "options": {
			   "cwd": "${workspaceFolder}"
		   },
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
		   "detail": "compiler: gcc"
		}
	]
}